# Neon Postgres (via Vercel Marketplace integration)
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# FRED API (free: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key_here

# Vercel Cron secret (set in Vercel dashboard)
CRON_SECRET=your_cron_secret_here

# TACO badge thresholds (optional, defaults shown)
# TACO_THRESHOLD_LOW=4.0
# TACO_THRESHOLD_HIGH=7.0
